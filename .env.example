# Copiar a .env y completar con los valores reales. NO subir .env al repositorio.

# Motor de la app: anywhere | mysql
DB_ENGINE=anywhere

# --- SQL Anywhere ---
# Opcion A: DSN ODBC ya configurado en Windows
ANYWHERE_DSN=
# Opcion B: conexion directa por driver + red
ANYWHERE_DRIVER=SQL Anywhere 12
ANYWHERE_HOST=<host_o_ip>
ANYWHERE_PORT=2638
ANYWHERE_SERVER=<nombre_servidor>
ANYWHERE_DB=<nombre_base>
ANYWHERE_UID=<usuario>
ANYWHERE_PWD=<clave>
ANYWHERE_TIMEOUT=15

# --- MySQL (migracion / VPS) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=emicar_insp
MYSQL_USER=<usuario>
MYSQL_PASSWORD=<clave>

# --- SMTP (opcional; el relay autentica por IP) ---
# SMTP_USER=
# SMTP_PASS=
